<?xml version="1.0" encoding="utf-8"?>
<!--
    MobileUO – Custom AndroidManifest.xml
    ======================================
    This manifest is merged by Unity with the generated one at build time.

    Key additions for background shard downloading:
      • FOREGROUND_SERVICE permission  – required on API 28+ to start a
        foreground service.
      • FOREGROUND_SERVICE_DATA_SYNC   – required on API 34+ (Android 14)
        to declare the foreground service type as data synchronisation.
      • POST_NOTIFICATIONS             – required on API 33+ (Android 13)
        to post the persistent download notification.
      • WAKE_LOCK                      – keeps the CPU awake while the
        service is running so downloads are not throttled.
      • DownloadForegroundService      – the service declaration itself,
        with android:foregroundServiceType="dataSync" for API 34+.
-->
<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.mobileuo.mobileuo">

    <!-- ================================================================
         Permissions
         ================================================================ -->

    <!-- Required to start a foreground service (API 28+) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!-- Required on Android 14 (API 34+) for dataSync foreground service type -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Required on Android 13 (API 33+) to post notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Keeps CPU running during download even when screen is off -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Network access (already present in Unity default manifest, listed
         here for completeness) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application>

        <!-- ============================================================
             Foreground Download Service
             ============================================================
             android:exported="false"   – only our own app can start it.
             android:stopWithTask="false" – service keeps running even if
               the user swipes the app away from recents.
             android:foregroundServiceType="dataSync" – required on API 34+
               to match the FOREGROUND_SERVICE_DATA_SYNC permission.
        -->
        <service
            android:name="com.mobileuo.mobileuo.DownloadForegroundService"
            android:exported="false"
            android:stopWithTask="false"
            android:foregroundServiceType="dataSync" />

    </application>

</manifest>
